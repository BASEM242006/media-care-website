# .env - environment variables for MediCare reminder server
# Copy this file to .env (remove the .template extension) and fill in your actual credentials.

# Twilio credentials for SMS sending
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890   # Your verified Twilio phone number in E.164 format

# How many minutes before the scheduled medication time the SMS should be sent
REMINDER_LEAD_MINUTES=15
